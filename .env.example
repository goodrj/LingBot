# Optional dashboard port.
PORT=3131

# Optional custom Playwright profile path for advanced runs.
# LINGUANA_USER_DATA_DIR=C:\path\to\profile

# Optional Playwright browser channel.
# LINGUANA_BROWSER_CHANNEL=chrome

# Advanced only: connect to a manually launched Chrome CDP endpoint.
# LINGUANA_CDP_URL=http://127.0.0.1:9222
